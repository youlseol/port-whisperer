{
  "name": "port-whisperer",
  "private": true,
  "type": "module",
  "description": "Workspace wrapper for the Rust port-whisperer implementation in rust/",
  "scripts": {
    "start": "cargo run --manifest-path rust/Cargo.toml --bin ports --",
    "help": "cargo run --manifest-path rust/Cargo.toml --bin ports -- --help",
    "test": "cargo test --manifest-path rust/Cargo.toml",
    "clippy": "cargo clippy --manifest-path rust/Cargo.toml -- -D warnings"
  }
}
